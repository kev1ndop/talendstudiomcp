# Talend Studio MCP Server Configuration
# Copy this file to .env and fill in your values

# Required: Path to the Talend workspace directory
TALEND_WORKSPACE_PATH=/home/user/TalendWorkspace

# Required: Default project name within the workspace
TALEND_DEFAULT_PROJECT=MY_PROJECT

# Optional: Path to Talend Studio installation (needed for CommandLine tool)
TALEND_STUDIO_PATH=/opt/TalendStudio-8.0.1

# Optional: Java home for Talend Studio
TALEND_JAVA_HOME=/usr/lib/jvm/java-11

# Optional: TAC server URL (for remote operations)
TALEND_TAC_URL=http://tac-server:8080/org.talend.administrator

# Optional: TAC credentials (stored in vault, not here in production)
TAC_AUTH_USER=admin@company.com
TAC_AUTH_PASS=

# Environment: DEV, STAGING, or PROD (controls write permissions)
TALEND_ENVIRONMENT=DEV

# Audit log path (defaults to {workspace}/.talend-mcp-audit.jsonl)
TALEND_AUDIT_LOG_PATH=

# Config file path (optional, overrides env vars)
TALEND_MCP_CONFIG=talend_mcp_config.json
